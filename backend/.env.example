PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=trustticket
DB_USER=root
DB_PASSWORD=your_mysql_password

CLIENT_URL=http://localhost:5173

# AI provider for the Ticket Advisor feature.
# "gemini" = real Google Gemini LLM, "local" = offline rule-based fallback engine.
AI_PROVIDER=gemini
# Google Gemini API key (free at https://aistudio.google.com/apikey).
# If missing/placeholder, the backend automatically uses the local engine.
AI_API_KEY=your_gemini_api_key_here
AI_MODEL=gemini-2.5-flash
# Let Gemini search the web (Google Search grounding) for current resale prices.
# "true" = web-grounded answers, "false" = model knowledge only.
AI_GROUNDING=true