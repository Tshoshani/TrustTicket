{
  "info": {
    "name": "TrustTicket API",
    "_postman_id": "trustticket-api-collection",
    "description": "Full CRUD API for TrustTicket - a secure ticket resale marketplace.\n\nSet the x-user-role header to simulate authentication:\n- admin: full access\n- manager: read/update users\n- user: create/update tickets, create/read transactions, view dashboards",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "General",
      "item": [
        {
          "name": "Get Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": []
            }
          }
        }
      ]
    },
